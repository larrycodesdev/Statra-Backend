{
    "openapi": "3.0.0",
    "info": {
        "title": "STATRA — Band Store API",
        "version": "1.0.0",
        "description": "API for the STATRA Band ordering website.\n\nHandles product info, order placement via **Korapay**, customer order tracking, and admin order management.\n\nAdmin endpoints require a static Bearer token (`STORE_ADMIN_TOKEN`).",
        "contact": {
            "email": "api@scdwellness.app"
        }
    },
    "servers": [
        {
            "url": "https://statrawebapp-f7gaa7bghfczhmf7.centralus-01.azurewebsites.net",
            "description": "Production"
        },
        {
            "url": "http://localhost:8000",
            "description": "Local dev"
        }
    ],
    "components": {
        "securitySchemes": {
            "adminToken": {
                "type": "http",
                "scheme": "bearer",
                "description": "Static STORE_ADMIN_TOKEN from server .env"
            }
        },
        "schemas": {
            "PlaceOrderRequest": {
                "type": "object",
                "required": ["first_name", "last_name", "email", "phone", "band_size", "quantity", "plan"],
                "properties": {
                    "first_name":     { "type": "string",  "example": "Jane" },
                    "last_name":      { "type": "string",  "example": "Daniel" },
                    "email":          { "type": "string",  "format": "email", "example": "jane@example.com" },
                    "phone":          { "type": "string",  "example": "+234 800 0000000" },
                    "street_address": { "type": "string",  "nullable": true, "example": "12 Marina Road" },
                    "city":           { "type": "string",  "nullable": true, "example": "Lagos" },
                    "state":          { "type": "string",  "nullable": true, "example": "Lagos" },
                    "band_size":      { "type": "string",  "enum": ["S", "M", "L"], "example": "M" },
                    "quantity":       { "type": "integer", "minimum": 1, "maximum": 10, "example": 1 },
                    "plan":           { "type": "string",  "enum": ["band_only", "band_care_plan"], "example": "band_care_plan" }
                }
            },
            "OrderTrackingResponse": {
                "type": "object",
                "properties": {
                    "order_number":   { "type": "string",  "example": "STR-2026-00001" },
                    "status":         { "type": "string",  "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled"], "example": "shipped" },
                    "payment_status": { "type": "string",  "enum": ["pending", "paid", "failed"], "example": "paid" },
                    "band_size":      { "type": "string",  "example": "M" },
                    "quantity":       { "type": "integer", "example": 1 },
                    "plan":           { "type": "string",  "example": "Band + Care Plan" },
                    "total":          { "type": "number",  "example": 149.00 },
                    "currency":       { "type": "string",  "example": "USD" },
                    "shipping": {
                        "type": "object",
                        "properties": {
                            "tracking_number": { "type": "string",  "nullable": true, "example": "1Z999AA10123456784" },
                            "courier":         { "type": "string",  "nullable": true, "example": "DHL" },
                            "shipped_at":      { "type": "string",  "format": "date-time", "nullable": true },
                            "estimated_days":  { "type": "string",  "example": "5–8 business days" }
                        }
                    },
                    "placed_at": { "type": "string", "format": "date-time" }
                }
            },
            "AdminOrder": {
                "type": "object",
                "properties": {
                    "id":                   { "type": "integer", "example": 1 },
                    "order_number":         { "type": "string",  "example": "STR-2026-00001" },
                    "first_name":           { "type": "string",  "example": "Jane" },
                    "last_name":            { "type": "string",  "example": "Daniel" },
                    "email":                { "type": "string",  "example": "jane@example.com" },
                    "phone":                { "type": "string",  "example": "+234 800 0000000" },
                    "street_address":       { "type": "string",  "nullable": true },
                    "city":                 { "type": "string",  "nullable": true },
                    "state":                { "type": "string",  "nullable": true },
                    "band_size":            { "type": "string",  "example": "M" },
                    "quantity":             { "type": "integer", "example": 1 },
                    "plan":                 { "type": "string",  "example": "band_care_plan" },
                    "unit_price":           { "type": "number",  "example": 149.00 },
                    "subtotal":             { "type": "number",  "example": 149.00 },
                    "discount":             { "type": "number",  "example": 50.00 },
                    "shipping":             { "type": "number",  "example": 0 },
                    "total":                { "type": "number",  "example": 149.00 },
                    "status":               { "type": "string",  "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled"] },
                    "payment_status":       { "type": "string",  "enum": ["pending", "paid", "failed"] },
                    "payment_reference":    { "type": "string",  "nullable": true },
                    "korapay_checkout_url": { "type": "string",  "nullable": true },
                    "tracking_number":      { "type": "string",  "nullable": true },
                    "courier":              { "type": "string",  "nullable": true },
                    "shipped_at":           { "type": "string",  "format": "date-time", "nullable": true },
                    "created_at":           { "type": "string",  "format": "date-time" }
                }
            }
        }
    },
    "tags": [
        { "name": "Product", "description": "Product info" },
        { "name": "Orders",  "description": "Place and track orders" },
        { "name": "Payment", "description": "Korapay webhook" },
        { "name": "Admin",   "description": "Admin order management — requires Bearer token (STORE_ADMIN_TOKEN)" }
    ],
    "paths": {
        "/api/v1/store/product": {
            "get": {
                "tags": ["Product"],
                "summary": "Get STATRA Band product info",
                "description": "Returns price, sizes, plans, shipping info, and marketing badges. No auth required.",
                "responses": {
                    "200": {
                        "description": "Product details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean", "example": true },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "name":           { "type": "string",  "example": "STATRA Band" },
                                                "description":    { "type": "string" },
                                                "price":          { "type": "number",  "example": 149.00 },
                                                "original_price": { "type": "number",  "example": 199.00 },
                                                "currency":       { "type": "string",  "example": "USD" },
                                                "plans":          { "type": "array",   "items": { "type": "object" } },
                                                "sizes":          { "type": "array",   "items": { "type": "object" } },
                                                "shipping":       { "type": "object" },
                                                "badges":         { "type": "array",   "items": { "type": "string" } }
                                            }
                                        }
                                    }
                                },
                                "example": {
                                    "success": true,
                                    "data": {
                                        "name": "STATRA Band",
                                        "price": 149.00,
                                        "original_price": 199.00,
                                        "currency": "USD",
                                        "plans": [
                                            { "id": "band_only",      "label": "Band Only",           "price": 149.00, "note": null },
                                            { "id": "band_care_plan", "label": "Band + Care Plan",    "price": 149.00, "note": "3 months Care Plan included free" }
                                        ],
                                        "sizes": [
                                            { "id": "S", "label": "S · 130–160mm" },
                                            { "id": "M", "label": "M · 155–185mm" },
                                            { "id": "L", "label": "L · 181–210mm" }
                                        ],
                                        "shipping": { "cost": 0, "label": "Free", "estimated_days": "5–8 business days" },
                                        "badges": ["Free shipping worldwide", "Clinically validated", "2-year warranty"]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/store/orders": {
            "post": {
                "tags": ["Orders"],
                "summary": "Place an order",
                "description": "Creates the order record, initialises a Korapay checkout session, and returns the `checkout_url` to redirect the customer to for payment.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/PlaceOrderRequest" },
                            "example": {
                                "first_name": "Jane",
                                "last_name":  "Daniel",
                                "email":      "jane@example.com",
                                "phone":      "+234 800 0000000",
                                "street_address": "12 Marina Road",
                                "city":       "Lagos",
                                "state":      "Lagos",
                                "band_size":  "M",
                                "quantity":   1,
                                "plan":       "band_care_plan"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Order created — redirect customer to checkout_url to complete payment",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success":  { "type": "boolean", "example": true },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "order_number": { "type": "string", "example": "STR-2026-00001" },
                                                "checkout_url": { "type": "string", "example": "https://checkout.korapay.com/pay/..." },
                                                "total":        { "type": "number", "example": 149.00 },
                                                "currency":     { "type": "string", "example": "USD" }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": { "description": "Validation error — missing or invalid fields" },
                    "502": { "description": "Korapay checkout initialisation failed" }
                }
            }
        },
        "/api/v1/store/orders/{orderNumber}": {
            "get": {
                "tags": ["Orders"],
                "summary": "Track an order",
                "description": "Public endpoint — customers enter their order number on the website to check status and tracking info.",
                "parameters": [
                    {
                        "name": "orderNumber",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string", "example": "STR-2026-00001" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order status and shipping/tracking info",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean", "example": true },
                                        "data":    { "$ref": "#/components/schemas/OrderTrackingResponse" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "description": "Order not found" }
                }
            }
        },
        "/api/v1/store/payment/webhook": {
            "post": {
                "tags": ["Payment"],
                "summary": "Korapay payment webhook",
                "description": "Called automatically by Korapay after a successful payment.\n\nVerifies the `X-Korapay-Signature` header (HMAC-SHA256 of raw payload against `KORAPAY_ENCRYPTION_KEY`), marks the order as paid, and queues an order confirmation email to the customer.\n\n**Do not call this endpoint manually.**",
                "parameters": [
                    {
                        "name": "X-Korapay-Signature",
                        "in": "header",
                        "required": true,
                        "description": "HMAC-SHA256 signature of the raw request body",
                        "schema": { "type": "string" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "event": { "type": "string", "example": "charge.success" },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "reference":         { "type": "string", "example": "STR-2026-00001" },
                                            "payment_reference": { "type": "string", "example": "KPY-..." }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Webhook acknowledged" },
                    "401": { "description": "Invalid signature" }
                }
            }
        },
        "/api/v1/store/admin/orders": {
            "get": {
                "tags": ["Admin"],
                "summary": "List all orders (paginated)",
                "security": [{ "adminToken": [] }],
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": { "type": "string", "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled"] }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "required": false,
                        "description": "Search by order number, email, or last name",
                        "schema": { "type": "string", "example": "STR-2026" }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": { "type": "integer", "default": 20, "example": 20 }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of orders",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean", "example": true },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "data":          { "type": "array", "items": { "$ref": "#/components/schemas/AdminOrder" } },
                                                "current_page":  { "type": "integer", "example": 1 },
                                                "total":         { "type": "integer", "example": 42 },
                                                "per_page":      { "type": "integer", "example": 20 },
                                                "last_page":     { "type": "integer", "example": 3 }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized — invalid or missing admin token" }
                }
            }
        },
        "/api/v1/store/admin/orders/{orderNumber}": {
            "get": {
                "tags": ["Admin"],
                "summary": "Get full detail of a single order",
                "security": [{ "adminToken": [] }],
                "parameters": [
                    {
                        "name": "orderNumber",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string", "example": "STR-2026-00001" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order detail",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean", "example": true },
                                        "data":    { "$ref": "#/components/schemas/AdminOrder" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "description": "Order not found" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/api/v1/store/admin/orders/{orderNumber}/status": {
            "patch": {
                "tags": ["Admin"],
                "summary": "Update order status",
                "description": "Sets the order to a new status.\n\nWhen setting status to `shipped`, `tracking_number` and `courier` are **required** — the system will automatically email the customer their tracking details.",
                "security": [{ "adminToken": [] }],
                "parameters": [
                    {
                        "name": "orderNumber",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string", "example": "STR-2026-00001" }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": ["status"],
                                "properties": {
                                    "status": {
                                        "type": "string",
                                        "enum": ["paid", "processing", "shipped", "delivered", "cancelled"],
                                        "example": "shipped"
                                    },
                                    "tracking_number": {
                                        "type": "string",
                                        "nullable": true,
                                        "example": "1Z999AA10123456784",
                                        "description": "Required when status = shipped"
                                    },
                                    "courier": {
                                        "type": "string",
                                        "nullable": true,
                                        "example": "DHL",
                                        "description": "Required when status = shipped"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Status updated — if shipped, tracking email sent to customer",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean", "example": true },
                                        "message": { "type": "string",  "example": "Order STR-2026-00001 updated to 'shipped'." },
                                        "data":    { "$ref": "#/components/schemas/AdminOrder" }
                                    }
                                }
                            }
                        }
                    },
                    "404": { "description": "Order not found" },
                    "422": { "description": "Validation error — e.g. tracking_number missing when status=shipped" },
                    "401": { "description": "Unauthorized" }
                }
            }
        }
    }
}
